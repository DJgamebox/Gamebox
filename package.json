{
  "name": "game-box",
  "version": "1.1.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.game.box",
    "productName": "游戏盒子",
    "win": {
      "icon": "app-icon.png",
      "target": "nsis"
    },
    "nsis": {
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "游戏盒子"
    }
  }
}
